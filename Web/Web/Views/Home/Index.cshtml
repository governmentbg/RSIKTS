@using Common.Enums.User
@model Common.ViewModels.Izbori.IzboriCompositeViewModel
@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="~/css/home.css" />
<link rel="stylesheet" href="~/js/bootstrap-select/css/bootstrap-select.css" />
<link rel="stylesheet" href="~/css/chartist.min.css">
<script>
    window.onload = function () {
      var data = {
              // A labels array that can contain any sort of values
              labels: 
                  @Html.Raw(Json.Serialize(@Model
                                                .DashboardSpravka
                                                .SustoqnieNaRegistraciite
                                                .Select(s => s.Col1).ToList()))
              ,
              // Our series array that contains series objects or in this case series data arrays
              series: [
                  @Html.Raw(Json.Serialize(@Model
                                                .DashboardSpravka
                                                .SustoqnieNaRegistraciite
                                                .Select(s => s.Col3).ToList()))
          ]
      };

      new Chartist.Bar('.ct-chart'
            , data
            ,{
              stackBars: true,
              axisY: {
                labelInterpolationFnc: function(value) {
                  return (value)+ '';
                }
              }
            }
        );
    }
</script>

