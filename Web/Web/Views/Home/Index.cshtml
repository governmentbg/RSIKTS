<div class="row data-picker-row">
        <div class="Dashboard">
            <div class="Table">
                <div class="Row">
                    <div class="Cell" style="width:300px">
                        <div class="item" style="height:202px;">
                            <p class="par">
                                <div style="padding-bottom:20px;">
                                    <img src="~/img/SofiaGERB.png" class="mb-4 objina-img" />
                                </div>
                            </p>
                        </div>
                    </div>

                    <div class="Cell" style="width:350px">              
                        <div class="item" style="height:202px;">
                            <p class="par">Брой лица по политически сили</p>
                            <div class="ct-chart ct-perfect-fourth"  
                                 style="height:180px; width:100%;">

                            </div>
                        </div>
                    </div>

                    <div class="Cell" style="width:250px;">
                        <div class="item" style="height:99px">
                            <p class="par">Брой въведени секции</p>
                            <h1 class="counter-center">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C1</h1>
                        </div>

                        <div class="item" style="height:100px">
                            <p class="par">Брой въведени лица</p>
                            <h1 class="counter-center">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C2</h1>
                        </div>
                    </div>

                    <div class="Cell" style="width:250px;">
                        <div class="item" style="height:38px;">
                            <table style="width:100%;">
                                <tr>
                                    <td> <p class="par">Председатели</p></td>
                                    <td> <h2 class="counter-right">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C3</h2></td>
                                </tr>
                            </table>
                        </div>
                        <div class="item" style="height:38px;">
                            <table style="width:100%">
                                <tr>
                                    <td> <p class="par">Зам. председатели</p></td>
                                    <td> <h2 class="counter-right">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C4</h2></td>
                                </tr>
                            </table>
                        </div>
                        <div class="item" style="height:38px;">
                            <table style="width:100%">
                                <tr>
                                    <td> <p class="par">Секретари</p></td>
                                    <td> <h2 class="counter-right">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C5</h2></td>
                                </tr>
                            </table>
                        </div>
                        <div class="item" style="height:38px;">
                            <table style="width:100%">
                                <tr>
