                                    <td> <h2 class="counter-right">@Model.DashboardSpravka.Razpredeleniq.ElementAt(0).C7</h2></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>


