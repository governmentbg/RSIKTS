@model ICollection<Common.ViewModels.Kvoti.KvotiViewModel>
@using Common.Static;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@*
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@
<table class="table table-bordered table-lica-register col-md-12" id="kvoti-table">
    <thead>
        <tr>
            <th style="width: 360px; text-align: center;vertical-align: top;">Политическа сила</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Председател</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Зам. председател</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Секретар</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Членове</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Брой рък. членове</th>
            <th style="width: 90px;  text-align: center;vertical-align: top;">Общо</th>
            <th style="width: 30px;"></th>
        </tr>
    </thead>
    <tbody>

        @foreach (var kvota in Model)
        {
            <tr>
                <td>@kvota.PoliticheskaSila</td>

                <td class="text-right">
                    @kvota.Precedatel
                </td>

                <td class="text-right">
                    @kvota.ZamestnikPrecedatel
                </td>

                <td class="text-right">
                    @kvota.Sekretar
                </td>

                <td class="text-right">
                    @kvota.Chlenove
                </td>

                <td class="text-right">
                    @(kvota.Precedatel + kvota.ZamestnikPrecedatel + kvota.Sekretar)
                </td>

                <td class="text-right">
                    @(kvota.Precedatel + kvota.ZamestnikPrecedatel + kvota.Sekretar + kvota.Chlenove)
                </td>

                <td class="lica-register-td-icon">
                    <button onclick="UpdateKvotiEditModal(this, '@kvota.Id', '@kvota.PoliticheskaSila')"
                            class="btn btn-outline-secondary lica-btn-with-icon-table lica-right-input-icon-table-btn"
                            type="button">
                        <img src="~/img/lica-images/Edit-128.png"
                             class="lica-right-input-icon-table lica-right-input-icon-table-edit" />
                    </button>
                </td>
            </tr>
        }
        @if (Model.Count < PaginationInfo.PageSize)
        {
            for (var i = 0; i < PaginationInfo.PageSize - Model.Count; i++)
            {
                <tr>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                </tr>
            }
        }

    </tbody>
</table>