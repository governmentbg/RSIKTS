@using Microsoft.AspNetCore.Identity
@using Common.ViewModels.User
@using Common.Enums.Spravki

@using Common.Enums.User
@using Common.Enums

@model Common.ViewModels.Obrabotki.AdminOptionsFilter

@inject Services.Interfaces.Nachislqvaniq.INachislqvaniqServices NachislqvaniqServices
@inject UserManager<SSOUserIdentity> UserManager
@inject Services.Interfaces.User.IUserServices UserServices

@{
    ViewData["Title"] = "Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var HasNachislqvaniq = NachislqvaniqServices.RaionHasNachislqvaniq(UserServices.GetUserRegion(UserManager.GetUserId(User)).Id);
}

<link rel="stylesheet" href="~/css/admin-menu.css" />
<link rel="stylesheet" href="~/css/obrabotki.css" />

<div class="row mb-2 text-center">
    <h3 style="width: 100%">Настройки</h3>
</div>

<div id="alerts-container"></div>

<div class="row justify-content-center">

    <!--v.2-->
    @if (User.IsInRole(Roles.Admin.GetDescription()))
    {
        <div class="col-md-3 admin-menu-box pl-0 pr-0">
            <button class="admin-menu-btn" onclick="location.href='@Url.Action("Index"
                          , "Home"
                          , new { Area = "Admin" })'">
                <img class="admin-menu-btn-img" src="~/img/admin-images/users.png" />
                <p>Потребители</p>
            </button>
        </div>
    }
    else
    {
        <div class="col-md-3 admin-menu-box pl-0 pr-0">
            <button class="admin-menu-btn disabled-link"
                    onclick="location.href='@Url.Action("Index"
