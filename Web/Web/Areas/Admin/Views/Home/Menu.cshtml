<!--v.2-->
@if (User.IsInRole(Roles.Admin.GetDescription()))
{
    <div class="row justify-content-center">
        <div class="col-md-3 admin-menu-box pl-0 pr-0">
            <button class="admin-menu-btn" data-toggle="modal" data-target="#admin-options-modal">
                <img class="admin-menu-btn-img" src="~/img/admin-images/Settings-02-128.png" />
                <p>
                    Преминаване
                    Избор/Тур
                </p>
            </button>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center">
        <div class="col-md-3 admin-menu-box pl-0 pr-0">
            <button class="admin-menu-btn disabled-link"
                    data-toggle="modal"
                    data-target="#admin-options-modal">
                <img class="admin-menu-btn-img" src="~/img/admin-images/Settings-02-128.png" />
                <p>
                    Преминаване
                    Избор/Тур
                </p>
            </button>
        </div>
    </div>
}

<!-- Add Modal -->
<div class="modal fade" id="admin-options-modal" tabindex="-1" role="dialog" aria-labelledby="admin-options-modal" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="lica-add-header">Изберете опция</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times; Изход</span>
                </button>
            </div>
            <div class="modal-content" id="admin-options-body">
                <partial model="Model" name="../PartialViews/AdminOptionsModal">
            </div>
        </div>
    </div>
</div>

<script>
    function ShowIzboriForm() {
        document.getElementById("new-izbor-form-container").setAttribute("style", "display:block;");
    }

    function HideIzboriForm() {
        document.getElementById("new-izbor-form-container").setAttribute("style", "display:none;");
    }
</script>

@section Scripts{
    <script src="~/js/jquery.form.js"></script>
    <script src="~/js/new-izbor-form-ajax.js"></script>
}