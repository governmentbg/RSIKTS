@using Common.ViewModels.User
@using Common.Static
@model AllUsersComposite
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<nav aria-label="Page navigation example" class="col-lg-10 col-md-12 ml-auto pagination-col">
    <form asp-area="Admin" asp-controller="Home" asp-action="GetUsersByPageAndRole" id="pagination-form">
        <input asp-for="CurrentPage" type="hidden" id="pagination-current-page" />
        <input asp-for="UserRoleFilter" type="hidden" id="pagination-user-role-filter" />
        <input asp-for="UsernameFilter" type="hidden" id="pagination-user-name-filter" />
        <ul class="pagination">
            @if (Model.MaxPages > PaginationInfo.NumberOfPages && Model.CurrentPage != 1)
            {
                <li class="page-item">
                    <button class="page-link" onclick="UpdatePagination(this,1, '@Model.UserRoleFilter','@Model.UsernameFilter')" aria-label="Previous" type="button">
                        <span aria-hidden="true">&laquo;</span>
                        <span class="sr-only">Previous</span>
                    </button>
                </li>
            }
            else if (Model.MaxPages > 0)
            {
                <li class="page-item disabled">
                    <button class="page-link" aria-label="Previous" type="button">
                        <span aria-hidden="true">&laquo;</span>
                        <span class="sr-only">Previous</span>
                    </button>
                </li>
            }
            @{
                if (Model.MaxPages <= PaginationInfo.NumberOfPages)
                {
                    for (var i = 1; i <= Model.MaxPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><button class="page-link" type="button">@i</button></li>
                        }
                        else
                        {
                            <li class="page-item"><button class="page-link" onclick="UpdatePagination(this,@i, '@Model.UserRoleFilter','@Model.UsernameFilter')" type="button">@i</button></li>
                        }
                    }
                }
                else
                {
                    var startingValue = 1;
                    var endingValue = 3;

                    if (Model.CurrentPage == Model.MaxPages)
                    {
                        startingValue = Model.MaxPages - (PaginationInfo.NumberOfPages) + 1;
                        endingValue = Model.MaxPages;
                    }
                    else if (Model.CurrentPage > 1)
                    {
                        startingValue = Model.CurrentPage - 1;
                        endingValue = Model.CurrentPage + 1;
                    }

                    for (var i = startingValue; i <= endingValue; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><button class="page-link" type="button">@i</button></li>
                        }
                        else
                        {
                            <li class="page-item"><button class="page-link" onclick="UpdatePagination(this,@i, '@Model.UserRoleFilter','@Model.UsernameFilter')" type="button">@i</button></li>
                        }
                    }
                }
            }

            @if (Model.MaxPages > PaginationInfo.NumberOfPages && Model.CurrentPage != Model.MaxPages)
            {
                <li class="page-item">
                    <buttton class="page-link" onclick="UpdatePagination(this,@Model.MaxPages, '@Model.UserRoleFilter','@Model.UsernameFilter')" type="button" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                        <span class="sr-only">Next</span>
                    </buttton>
                </li>
            }
            else if (Model.MaxPages > 0)
            {
                <li class="page-item disabled">
                    <button class="page-link" aria-label="Next" type="button">
                        <span aria-hidden="true">&raquo;</span>
                        <span class="sr-only">Next</span>
                    </button>
                </li>
            }
        </ul>
    </form>
</nav>