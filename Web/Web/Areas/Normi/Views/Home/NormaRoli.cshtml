@using  Common.ViewModels.List;
@model Common.ViewModels.List.NormiRoliComposite
@inject Services.Interfaces.Izbori.IIzboriServices _izboriServices;
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/lica-register.css" />
<link rel="stylesheet" href="~/css/lica.css" />
<link rel="stylesheet" href="~/js/bootstrap-select/css/bootstrap-select.css" />


<div class="row mb-2 text-center">
    <h3 style="width: 100%">Настройки плащане по длъжност</h3>
</div>

<div class="row">
    
    <div class="form-group col-md-6 pl-0 mb-2">
        <span>Вид секция</span>
        <select asp-items="Model.VidSekcii"
                class="selectpicker form-control show-tick col-md-12"
                data-live-search="true"
                data-size="5"
                id="section-type">
        </select>
    </div>

    @if (_izboriServices.GetIzborMaxTUR() > 1)
    {
        <div class="form-group col-md-6 pr-0 mb-2">
            <span>Тур</span>
            <select class="selectpicker form-control show-tick col-md-12"
                    data-live-search="true"
                    data-size="5"
                    id="tur-type">
                <option value="1">1</option>
                <option value="2">2</option>
            </select>
        </div>
    }
</div>

<partial model="Model.Roli.Select(r => new CodePositionsWithMoneyViewModel 
                                    { Id = r.Id
                                        , Nkode = r.Nkode
                                        , Nime = r.Nime
                                        , Money = r.Money
                                        , Pkode = r.Pkode
                                        , Koga = r.Koga
                                        , User = r.User
                                        , Status = r.Status
                                    }).ToList()" 
                name="../PartialViews/NormiTablePartialView" />

<!-- Edit Modal -->
<div class="modal fade" id="normi-edit-modal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="normi-edit-header">Редактиране</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times; Изход</span>
                </button>
            </div>
            <form asp-area="Normi" asp-controller="Home" asp-action="EditNormaRoli" id="normi-edit-form" class="form-horizontal">
                <div class="modal-body text-center" id="normi-edit-modal-body">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Отказ</button>
                    <button type="submit" class="btn btn-primary">Редактиране</button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/js/bootstrap-select/js/bootstrap-select.js"></script>
    <script src="~/js/jquery.form.js"></script>
    <script src="~/js/normi-roli-form-ajax.js"></script>
    <script src="~/js/normi-roli-crud-main.js"></script>
}
