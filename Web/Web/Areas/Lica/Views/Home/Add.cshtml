                            <span asp-validation-for="Obrazovanie" class="text-danger validation-height col-md-12"></span>
                        </div>
                        <div class="form-group col-md-6 form-inline mt-sm-auto mb-lg-auto">
                            <label asp-for="Specialnost"></label>
                            <select asp-for="Specialnost" asp-items="Model.AllSpecialnosti" class="selectpicker form-control show-tick col-12" data-live-search="true" data-size="5" id="profesion"></select>
                            <span asp-validation-for="Specialnost" class="text-danger validation-height col-md-12"></span>
                        </div>
                    </div>
