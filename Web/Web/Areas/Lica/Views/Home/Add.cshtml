@model Common.ViewModels.Lica.LicaAddViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Index";

}

<link rel="stylesheet" href="~/css/lica.css" />
<link rel="stylesheet" href="~/js/bootstrap-select/css/bootstrap-select.css" />


<div class="row lica-egn-row">
    <div class="input-group col-lg-2 col-md-2 lica-egn-col">
        <select asp-for="Vid" 
                class="selectpicker form-control show-tick col-12" 
                data-live-search="true" 
                data-size="5" 
                id="videgn">
            <option value="0">ЕГН</option>
            <option value="2">ЛНЧ</option>
        </select>
        <span class="text-danger validation-height col-md-12"></span>
    </div>
    <div class="input-group col-lg-4 col-md-5 lica-egn-col">
        <input asp-for="Egn" 
               class="form-control lica-input-egn lica-input" 
               type="text" 
               id="egn" 
               placeholder="*" 
               onfocus="this.placeholder = ''" 
               onblur="checkGrao();" />
        <span asp-validation-for="Egn" class="text-danger validation-height col-md-12"></span>
    </div>
    <div>
        <p class="text-danger" style="padding: 10px;">@Model.ImpMessage</p>
    </div>
    <div class="input-group col-md-1 lica-egn-col ml-auto">
        <button class="btn lica-btn-save"><img class="lica-btn-save-img" src="~/img/lica-images/save.png" /></button>
    </div>
</div>

<input asp-for="USER" type="hidden" />
<input type="hidden" asp-for="FromSelectedSik" />

<div class="row lica-form-row">
    <div class="col-md-12 lica-form">
