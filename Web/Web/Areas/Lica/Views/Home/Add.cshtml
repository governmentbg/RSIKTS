                        <div class="form-group col-md-4 form-inline mt-sm-auto mb-lg-auto">
                            <label asp-for="Ime1"></label>
                            <input asp-for="Ime1" class="form-control lica-input col-12" type="text" id="ime" placeholder="*" onfocus="this.placeholder = ''" onblur="this.placeholder = '*'" />
                            <span asp-validation-for="Ime1" class="text-danger validation-height col-md-12"></span>
                        </div>
                        <div class="form-group col-md-4 form-inline mt-sm-auto mb-lg-auto">
                            <label asp-for="Ime2"></label>
                            <input asp-for="Ime2" class="form-control lica-input col-12" type="text" id="surname" />
                            <span asp-validation-for="Ime2" class="text-danger validation-height col-md-12"></span>
                        </div>
                        <div class="form-group col-md-4 form-inline mt-sm-auto mb-lg-auto">
                            <label asp-for="Ime3"></label>
                            <input asp-for="Ime3" class="form-control lica-input col-12" type="text" id="family-primary" placeholder="*" onfocus="this.placeholder = ''" onblur="this.placeholder = '*'" />
                            <span asp-validation-for="Ime3" class="text-danger validation-height col-md-12"></span>
                        </div>
                    </div>
