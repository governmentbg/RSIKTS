@model List<Common.ViewModels.Lica.LicaForSpravka211ViewModel>
@using Microsoft.AspNetCore.Identity
@using Common.ViewModels.User
@inject UserManager<SSOUserIdentity> UserManager
@inject Services.Interfaces.User.IUserServices UserServices
@inject Services.Interfaces.Izbori.IIzboriServices IzboriServices


@{var groups = Model.GroupBy(s => s.NmIzbRajon).ToList();}


<link rel="stylesheet" href="~/lib/sweet-alert/sweetalert2.min.css">
<link rel="stylesheet" href="~/css/spravka-print-landscape.css" />
<link rel="stylesheet" href="~/css/spravki.css" />

<div id="wrapper">
    <div class="navbar-landscape">
        <button class="prnbtn"
                id="printbtn"
                type="button"
                onclick="printpage()">
            <img src="~/img/spravki-images/Print-128.png"
                 class="nav-img"
                 style="height:32px;">
            <br />
            Печат
        </button>

        <button class="prnbtn"
                id="closebtn"
                type="button"
                onclick="closepage();">
            <img src="~/img/navbar-images/logout-128.png"
                 class="nav-img"
                 style="height:32px;">
            <br />
            Изход
        </button>
    </div>

    <div class="container-landscape">
        <div>
            <table style="width:100%;">
                <tbody>
                    <tr style="height:30px">
                        <td style="text-align: left;">
                            <p>Избори: <strong>@IzboriServices.GetIzborDescription()</strong></p>
                        </td>
                        <td style="text-align: right;">
                            <p>
                                Отпечатано на:
                                <script>document.write(new Date().toLocaleString());</script>
                            </p>
                        </td>
                    </tr>
                    <tr style="height:30px">
                        <td style="text-align: left;">
                            <p></p>
                        </td>
                        <td style="text-align: right;">
                            <p>Изготвил: @UserServices.GetIdentityUserById(UserManager.GetUserId(User)).Names</p>
                        </td>
                    </tr>
                </tbody>
            </table>

            <p>&nbsp;</p>
        </div>

        <h3 style="text-align: center;">Списък на лицата по секции</h3>
        <!--group section -->
        @for (var i = 0; i < groups.Count; i++)
        {
            <div>
                <p>&nbsp;</p>
                <p>@groups[i].ElementAt(0).NmIzbRajon</p>

                @{var toa = Model.Where(s => s.NmIzbRajon == groups[i].ElementAt(0).NmIzbRajon).GroupBy(s => s.NmRajon).ToList();}

                @for (var j = 0; j < toa.Count; j++)
                {
                    <p>@toa[j].ElementAt(0).NmRajon</p>

                    <table id="spravka">
                        <tbody>
                            <tr>
                                <th style="width: 60px; "><strong>Секция</strong></th>
                                <th style="width: 130px;"><strong>Длъжност</strong></th>
                                <th style="width: 180px;"><strong>Име, Презиме, Фамилия</strong></th>
                                <th style="width: 140px;"><strong>Политическа сила</strong></th>
                                <th style="width: 110px;"><strong>Телефон</strong></th>
                                <th style="width: 110px;"><strong>Образование</strong></th>
                                <th style="width: 110px;"><strong>Специалност</strong></th>
                            </tr>

                            @foreach (var lice in toa[j])
                            {
                                <!--detail section -->
                                <tr>
                                    <td style="text-align: left;">@lice.SikFullCode</td>
                                    <td style="text-align: left;">@lice.Rolia</td>
                                    <td style="text-align: left;">@lice.Imena</td>
                                    <td style="text-align: left;">@lice.Sila</td>
                                    <td style="text-align: left;">@lice.Telephone</td>
                                    <td style="text-align: left;">@lice.Obrazovanie</td>
                                    <td style="text-align: left;">@lice.Specialnost</td>
                                </tr>
                                <!--end detail section -->
                            }
                        </tbody>
                    </table>
                }
            </div>

            if (groups[i] != groups[groups.Count - 1])
            {
                <p style="page-break-after: always;">&nbsp;</p>
                <p style="page-break-before: always;">&nbsp;</p>
            }

        }
    </div>
</div>

<script src="~/js/print.js"></script>
<script src="~/lib/sweet-alert/sweetalert2.min.js"></script>
<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/js/bootstrap-select/js/bootstrap-select.js"></script>
