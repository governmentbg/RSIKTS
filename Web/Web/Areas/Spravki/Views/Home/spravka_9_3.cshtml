@model List<Common.ViewModels.Spravki.SustoqnieNaRegistraciiteSpravkaViewModel>

@using Microsoft.AspNetCore.Identity
@using Common.ViewModels.User
@inject UserManager<SSOUserIdentity> UserManager
@inject Services.Interfaces.User.IUserServices UserServices
@inject Services.Interfaces.Raion.IRaionServices RaionServices
 
@{var groups = Model.GroupBy(s => new { s.NmIzbor }).ToList();}


<link rel="stylesheet" href="~/lib/sweet-alert/sweetalert2.min.css">
<link rel="stylesheet" href="~/css/spravka-print.css" />
<link rel="stylesheet" href="~/css/spravki.css" />

<div id="wrapper">
    <div style=" margin-left: 5px;position:fixed; width:110px;">
        <button class="prnbtn"
                id="printbtn"
                type="button"
                onclick="printpage()">
            <img src="~/img/spravki-images/Print-128.png"
                 class="nav-img"
                 style="height:32px;">
            <br />
            Печат
        </button>

        <button class="prnbtn"
                id="closebtn"
                type="button"
                onclick="closepage();">
            <img src="~/img/navbar-images/logout-128.png"
                 class="nav-img"
                 style="height:32px;">
            <br />
            Изход
        </button>
    </div>
  
    <div class="container">
        <table style="width:100%;">
            <tbody>
                <tr style="height:30px">
                    <td style="text-align: left;">
                        <p>Избори: <strong>@groups[0].ElementAt(0).NmIzbor</strong></p>
                    </td>
                    <td style="text-align: right;">
                        <p>
                            Отпечатано на:
                            <script>document.write(new Date().toLocaleString());</script>
                        </p>
                    </td>
                </tr>
                <tr style="height:30px">
                    <td style="text-align: left;">
                        <p>Административен район: <strong> @UserServices.GetUserRegion(UserManager.GetUserId(User)).Name</strong></p>
                    </td>
                    <td style="text-align: right;">
                        <p>Изготвил: @UserServices.GetIdentityUserById(UserManager.GetUserId(User)).Names</p>
                    </td>
                </tr>
            </tbody>
        </table>
         
        <p>&nbsp;</p>
        <h3 style="text-align: center;"><strong>Разпределение на регистрираните лица</strong></h3>
        <h3 style="text-align: center;"><strong>за @Model.ElementAt(0).Rolq</strong></h3>
        <p style="text-align: center;">
            <strong>
                към
                <script>document.write(new Date().toLocaleString());</script>
            </strong>
        </p>
        <!--group section -->
        @for (var i = 0; i < groups.Count; i++)
        {
            <div>
                <p>&nbsp;</p>
                <table style="height: 49px; width: 100%;" id="spravka">
                    <tbody>
                        <tr>
                            <th style="width: 5%;"><strong>№</strong></th>
                            <th style="width: 10%;"><strong>Код</strong></th>
                            <th style="width: 33%;"><strong>Политическа сила</strong></th>
                            <th style="width: 11%;"><strong>Брой лица</strong></th>
                            <th style="width: 12%;"><strong>Процент</strong></th>
                        </tr>
                        <!--detail section -->
                        @foreach (var data in groups[i])
                        {
                            <tr>
                                <td style="text-align: center;">@data.Id</td>
                                <td style="text-align: center;">@data.Col1</td>
                                <td style="text-align: left;">@data.Col2</td>
                                <td style="text-align: right;">@data.Col3</td>
                                <td style="text-align: right;">@data.Col4</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (groups[i] != groups[groups.Count - 1])
            {
                <p style="page-break-after: always;">&nbsp;</p>
                <p style="page-break-before: always;">&nbsp;</p>
            }
        }
    </div>
</div>


<script src="~/js/print.js"></script>
<script src="~/lib/sweet-alert/sweetalert2.min.js"></script>
<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/js/bootstrap-select/js/bootstrap-select.js"></script>


