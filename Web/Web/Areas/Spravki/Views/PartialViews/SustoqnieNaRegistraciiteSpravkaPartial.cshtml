@using Common.ViewModels.Spravki
@using Common.Static
@model RoliSpravkaFilter
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@*
    For more information on enabling MVC for empty projects, visit http://go.microsoft.com/fwlink/?LinkID=397860
*@


<div class="modal fade" id="sustoqnieNaRegistraciiteSpravkaModal" tabindex="-1" role="dialog" aria-labelledby="sustoqnieNaRegistraciiteSpravkaModal" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Справка</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form target="_blank" asp-area="Spravki" asp-controller="Home" asp-action="GetSustoqnieNaRegistraciiteSpravka" method="get">
                    <label asp-for="Rolq"></label>
                    <select asp-for="Rolq" asp-items="Model.AllRoli" class="selectpicker form-control show-tick col-12" data-live-search="true" data-size="5"></select>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-primary">Изпълни</button>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Затвори</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>