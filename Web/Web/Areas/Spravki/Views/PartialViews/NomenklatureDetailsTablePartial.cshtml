@model Common.ViewModels.Spravki.NomenklatureComposite
@using Common.Enums
@using Common.Enums.User
@using Common.Enums.Spravki
@using Common.Static
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<table class="table table-bordered table-nomenklature-register col-md-12" id="nomenklature-table">
    <thead>
        <tr>
            @if (Model.NomenklatureId == NomenklatureIds.Ulici)
            {
                <th style="text-align:center;">Код нас. място</th>
                <th style="text-align:center;">Код улица</th>
            }
            else
            {
                if (Model.NomenklatureId != NomenklatureIds.Dokumenti) { 
                    <th style="text-align:center;">Код</th>
                }
            }
            <th style="text-align:center;">Наименование</th>

            @if (Model.NomenklatureId == NomenklatureIds.VidoveOperacii
              || Model.NomenklatureId == NomenklatureIds.VidovePrazniciNaSekcii
              || Model.NomenklatureId == NomenklatureIds.VidoveSekcii
              || Model.NomenklatureId == NomenklatureIds.Roli
              || Model.NomenklatureId == NomenklatureIds.PoliticheskiSili
              || Model.NomenklatureId == NomenklatureIds.DanuchniParametri)
            {
                <th style="text-align:center;">Активен</th>
            }
            else
            {
                if (Model.NomenklatureId == NomenklatureIds.Dokumenti)
                {
                    <th style="text-align:center;">Активно</th>
                }
            }

            @if (Model.NomenklatureId == NomenklatureIds.DanuchniParametri)
            {
                <th style="text-align:center;">Стойност</th>
            }

            @if (User.IsInRole(Roles.Admin.GetDescription()) || Model.NomenklatureId == NomenklatureIds.Dokumenti)
            {
                <th></th>
                <th></th>
            }
            </tr>
    </thead>
    <tbody>

        @foreach (var nomenklature in Model.AllNomenklatures)
        {
            <tr>
                @if (nomenklature.Has_Kod_Nas && nomenklature.Has_Kod_Ulica)
                {
                    <td>@nomenklature.Kod_Nas</td>
                    <td>@nomenklature.Kod_Ulica</td>
                }
                else
                {
                    if (Model.NomenklatureId != NomenklatureIds.Dokumenti)
                    {
                        <td>@nomenklature.Code</td>
                    }
                }
                <td>
                    @nomenklature.Name
                </td>
                @if (nomenklature.Has_Status)
                {
                    <td style="text-align:center;">@(nomenklature.Status == true ? "Да" : "Не")</td>
                }

                @if (nomenklature.Has_Stoinost)
                {
                    <td style="text-align:right;">@nomenklature.Stoinost</td>
                }

                @if (User.IsInRole(Roles.Admin.GetDescription()) || Model.NomenklatureId == NomenklatureIds.Dokumenti)
                {

                    @if (nomenklature.Has_ID_Party)
                    {
                        <td class="nomenklature-register-td-icon"><button onclick="UpdateNomenklatureEditModal(this, '@Model.NomenklatureId.GetDescription()', '' , '@nomenklature.ID_Party' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Edit-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-edit" /></button></td>
                        <td class="nomenklature-register-td-icon"><button onclick="DeleteNomenklaturePopup(this, '@Model.NomenklatureId.GetDescription()', '' , '@nomenklature.ID_Party' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Garbage-Closed-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-garbage" /></button></td>
                    }

                    @if (nomenklature.Has_ID_Shablon)
                    {
                        <td class="nomenklature-register-td-icon"><button onclick="UpdateNomenklatureEditModal(this, '@Model.NomenklatureId.GetDescription()','', '@nomenklature.ID_Shablon' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Edit-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-edit" /></button></td>
                        <td class="nomenklature-register-td-icon"><button onclick="DeleteNomenklaturePopup(this, '@Model.NomenklatureId.GetDescription()', '' , '@nomenklature.ID_Shablon' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Garbage-Closed-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-garbage" /></button></td>
                    }

                    @if (nomenklature.Has_ID_Party == false && nomenklature.Has_ID_Shablon == false)
                    {
                        <td class="nomenklature-register-td-icon"><button onclick="UpdateNomenklatureEditModal(this, '@Model.NomenklatureId.GetDescription()', '@nomenklature.Code', '0' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Edit-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-edit" /></button></td>
                        <td class="nomenklature-register-td-icon"><button onclick="DeleteNomenklaturePopup(this, '@Model.NomenklatureId.GetDescription()', '@nomenklature.Code' , '0' )" class="btn btn-outline-secondary nomenklature-btn-with-icon-table nomenklature-right-input-icon-table-btn" type="button"><img src="~/img/nomenklature-images/Garbage-Closed-128.png" class="nomenklature-right-input-icon-table nomenklature-right-input-icon-table-garbage" /></button></td>
                    }
                }
            </tr>
        }

        @if (Model.AllNomenklatures.Count < PaginationInfo.PageSize)
        {
            for (var i = 0; i < PaginationInfo.PageSize - Model.AllNomenklatures.Count; i++)
            {
                <tr>
                    <td></td>
                    
                    @if (Model.NomenklatureId != NomenklatureIds.Dokumenti) { 
                        <td></td>
                    }

                    @if (Model.NomenklatureId == NomenklatureIds.Dokumenti 
                        || Model.NomenklatureId == NomenklatureIds.VidoveOperacii 
                        || Model.NomenklatureId == NomenklatureIds.VidovePrazniciNaSekcii 
                        || Model.NomenklatureId == NomenklatureIds.VidoveSekcii 
                        || Model.NomenklatureId == NomenklatureIds.Roli 
                        || Model.NomenklatureId == NomenklatureIds.PoliticheskiSili 
                        || Model.NomenklatureId == NomenklatureIds.DanuchniParametri)
                    {
                        <td></td>
                    }
                    @if (Model.NomenklatureId == NomenklatureIds.DanuchniParametri)
                    {
                        <td></td>
                    }
                    @if (Model.NomenklatureId == NomenklatureIds.Ulici)
                    {
                        <td></td>
                    }

                    @if (User.IsInRole(Roles.Admin.GetDescription()) || Model.NomenklatureId == NomenklatureIds.Dokumenti)
                    {
                        <td></td>
                        <td></td>
                    }

                </tr>
            }
         }

    </tbody>
</table>
