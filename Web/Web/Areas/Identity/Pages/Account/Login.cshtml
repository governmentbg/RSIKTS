@page
@model LoginModel

<link rel="stylesheet" href="~/css/login.css" />

<div class="row login-form-row">
    <div class="col-lg-6 login-form-col">
        <section>
            <form id="account" method="post">
                <br/>
                <div class="row">
                    <div class="login-icon">
                        <img class="login-icon-img" src="~/img/login-images/User-128.png"/>
                    </div>
                    <div class="col-md-5"><img class="login-form-icon" src="~/img/login-images/SofiaGERB.png"/></div>
                    <div class="col-md-7">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group">
                            <label asp-for="Input.Username"></label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" id="username-add-on"><img class="login-input-icons" src="~/img/login-images/login-user.png"/></span>
                                </div>
                                <input asp-for="Input.Username" class="form-control"/>
                                <span asp-validation-for="Input.Username" class="text-danger"></span>
                            </div>

                        </div>
                        <div class="form-group">
                            <label asp-for="Input.Password"></label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text" id="password-add-on"><img class="login-input-icons" src="~/img/login-images/locked-files.png"/></span>
                                </div>
                                <input asp-for="Input.Password" class="form-control"/>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <div class="checkbox">
                                <label asp-for="Input.RememberMe">
                                    <input asp-for="Input.RememberMe"/>
                                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary login-submit-btn">Вход</button>
                        </div>
                    </div>
                </div>
                <hr/>
                <div class="form-group text-right">
                    <p>
                        <a id="forgot-password" asp-page="./ForgotPassword">Забравена парола?</a>
                    </p>
                </div>
            </form>
        </section>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
