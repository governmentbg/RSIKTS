@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model Common.ViewModels.Parameters.IzbDateViewModel
@inject Services.Interfaces.Izbori.IIzboriServices IzboriServices;

@{
    ViewData["Title"] = "ParameterEdit";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var izboriMaxTur = IzboriServices.GetIzborMaxTUR();

}

<link rel="stylesheet" href="~/css/lica.css" />

<div class="row mb-2 text-center">
    <h3 style="width: 100%">Допълнителни настройки -> Дати на изборите</h3>
</div>


<div id="new-izbor-form-container">
    <form asp-area="Parameters"
          asp-controller="Home"
          asp-action="EditNTopMain"
          id="new-izbor-form"
          class="form-horizontal"
          autocomplete="off">

        <div id="alerts-container" class="col-10" style="padding-left:0px;"></div>

        <div class="col-7 no-padding ml-auto">
            <button type="submit" class="btn lica-btn-save">
                <img class="lica-btn-save-img" src="~/img/lica-images/save.png" />
            </button>
        </div>

        <div class="row">
            <div class="form-group col-md-6 offset-md-3">
                <label asp-for="Naimenovanie"></label>
                <input asp-for="Naimenovanie"
                       class="form-control"
                       placeholder="*"
                       onfocus="this.placeholder = ''"
                       onblur="this.placeholder = '*'" />
                <span asp-validation-for="Naimenovanie" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="form-group col-md-6 offset-md-3">
                <label asp-for="DateTur1" id="lbldatetur1"></label>
                <input asp-for="DateTur1"
                       class="form-control"
                       placeholder="DD/MM/YYYY"
                       onfocus="this.placeholder = ''"
                       onblur="this.placeholder = '*'"
                       required pattern="\d{4}-\d{2}-\d{2}"
                       type="date" />
                <span asp-validation-for="DateTur1" class="text-danger"></span>
            </div>
        </div>

        @if (izboriMaxTur > 1)
        {
            <div class="row">
                <div class="form-group col-md-6 offset-md-3">
                    <label asp-for="DateTur2"></label>
                    <input asp-for="DateTur2"
                           class="form-control"
                           placeholder="DD/MM/YYYY"
                           onfocus="this.placeholder = ''"
                           onblur="this.placeholder = '*'"
                           required pattern="\d{2}-\d{2}-\d{4}"
                           type="date" />
                    <span asp-validation-for="DateTur2" class="text-danger"></span>
                </div>
            </div>
        }


    </form>
</div>

@section Scripts {
    <script src="~/js/jquery.form.js"></script>
    <script src="~/js/parameters-crud.js"></script>
    <script src="~/js/parameters-nomenclature-form-ajax.js"></script>
}
