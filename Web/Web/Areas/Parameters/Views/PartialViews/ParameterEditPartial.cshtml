@model Common.ViewModels.Parameters.ParametersViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "ParameterEdit";
}

<input type="hidden" asp-for="Kod" />
<input type="hidden" asp-for="Opisanie" />

<div class="row">
    <div class="form-group col-md-12">
        <h5 style="text-align:left;padding-left:0px;margin-left:0px; ">@Model.Opisanie </h5>
    </div>
</div>


@if (Model.Kod == "52" || Model.Kod == "53" || Model.Kod == "54" || Model.Kod == "55")
{
    <div class="row mb-4">
        <label asp-for="Znachenie"></label>
        <input asp-for="Znachenie"
               type="date"
               min="2020-01-01"
               max="2030-12-31"
               id="date_timepicker"
               class="form-control col-md-12"
               placeholder="*"
               onfocus="this.placeholder = ''"
               onblur="this.placeholder = '*'" />
        <span asp-validation-for="Znachenie" class="text-danger"></span>
    </div>
}
else
{
    <div class="row mb-4">
        <label asp-for="Znachenie"></label>
        <input asp-for="Znachenie"
               class="form-control col-md-12"
               placeholder="*"
               onfocus="this.placeholder = ''"
               onblur="this.placeholder = '*'" />
        <span asp-validation-for="Znachenie" class="text-danger"></span>
    </div>
}

<div class="row">
    <div class="form-group col-md-12 pl-0">
        <div>
            <label class="checkbox-container text-left">
                Активно?
                <input asp-for="Status" class="form-check-input" type="checkbox">
                <span class="checkmark"></span>
            </label>
        </div>
    </div>
</div>
