@model Common.ViewModels.Parameters.NomenclaturesViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "NomenclatureEdit";
}

<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="Description" />

<div class="row">
    <label asp-for="Tip"></label>
    <div class="form-group col-md-12 pl-0">

        <select asp-for="Tip"
                asp-items="Model.TipNomenclatures"
                class="selectpicker form-control show-tick"
                data-live-search="true"
                data-size="5"
                id="tip-select">
        </select>

        <span asp-validation-for="Tip"
              class="text-danger validation-height col-md-4">
        </span>
    </div>
</div>

<div class="row">
    <div class="form-group col-md-4 pl-0">
        <div>
            <label class="checkbox-container text-left">
                Активно?
                <input asp-for="Status" class="form-check-input" type="checkbox">
                <span class="checkmark"></span>
            </label>
        </div>
    </div>
</div>
